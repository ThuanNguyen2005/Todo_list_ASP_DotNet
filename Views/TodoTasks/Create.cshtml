@model Todo_list.Models.TodoTask

@{
    ViewData["Title"] = "Create";
}

<h1>Thêm công việc mới</h1>

<h4>TodoTask</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- TITLE -->
            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label">Tiêu đề</label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- STATUS -->
            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="trangThai" />
                    @Html.DisplayNameFor(model => model.trangThai)
                </label>
            </div>

            <!-- CATEGORY -->
            <<div class="form-group mb-3">
                <label asp-for="danhMuc" class="control-label">Danh mục</label>
                <select asp-for="danhMuc" class="form-select"
                        asp-items="@(new SelectList(ViewBag.Categories))">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="danhMuc" class="text-danger"></span>
            </div>

            <!-- DEADLINE -->
            <div class="form-group mb-3">
                <label asp-for="Deadline" class="control-label">Hạn chót</label>
                <input asp-for="Deadline" type="date" class="form-control" />
                <span asp-validation-for="Deadline" class="text-danger"></span>
            </div>

            <!-- BUTTON -->
            <div class="form-group mt-3">
                <input type="submit" value="Tạo mới" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}