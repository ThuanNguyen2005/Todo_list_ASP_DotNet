@model IEnumerable<Todo_list.Models.TodoTask>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h4 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>Danh sách việc cần làm</h4>
            <a asp-action="Create" class="btn btn-light btn-sm fw-bold">
                <i class="fas fa-plus-circle me-1"></i> Tạo nhiệm vụ mới
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tiêu đề</th>
                            <th>Mô tả</th>
                            <th class="text-center">Trạng thái</th>
                            <th>Tạo lúc</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.Title</td>
                                <td class="text-muted">@item.Description</td>
                                <td class="text-center">
                                    @if (item.IsCompleted)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning px-3">Đang làm</span>
                                    }
                                </td>
                                <td><small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td class="text-center pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                            <i class="fas fa-info-circle"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Xoá">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>