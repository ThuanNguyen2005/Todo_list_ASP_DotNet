@model List<Todo_list.Models.TodoTask>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Danh sách nhiệm vụ</h2>
    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createTaskModal">
        <i class="bi bi-plus-lg"></i> Tạo nhiệm vụ mới
    </button>
</div>

<div class="todo-list">
    @foreach (var task in Model)
    {
        var isOverdue = task.Deadline != null && task.Deadline < DateTime.Now;
        var isDueSoon = task.Deadline != null && task.Deadline >= DateTime.Now && task.Deadline <= DateTime.Now.AddDays(1);

        <div class="card mb-2 shadow-sm border-0 rounded-3 task-card">
            <div class="card-body d-flex align-items-center p-3">

                <!-- CHECKBOX -->
                <input type="checkbox"
                       class="form-check-input me-3"
                       style="width: 22px; height: 22px;"
                       onchange="location.href='/TodoTasks/ToggleComplete/@task.Id'"
                @(task.trangThai ? "checked" : "")>

                <!-- NỘI DUNG -->
                <div class="flex-grow-1">
                    <h6 class="mb-0 @(task.trangThai ? "text-decoration-line-through text-muted" : "fw-bold")">
                        @task.Title
                    </h6>

                    <small class="text-muted">
                        @task.Description |
                        <i class="bi bi-clock"></i>
                        @(task.Deadline?.ToString("dd/MM/yyyy") ?? "Không có hạn")
                    </small>

                    <!-- THÔNG BÁO -->
                    <div>
                        @if (isOverdue)
                        {
                            <span class="badge bg-danger">Quá hạn</span>
                        }
                        else if (isDueSoon)
                        {
                            <span class="badge bg-warning text-dark">Sắp đến hạn</span>
                        }
                    </div>
                </div>

                <!-- DANH MỤC -->
                <span class="badge bg-info-soft text-info rounded-pill me-3 px-3">
                    @task.danhMuc
                </span>

                <!-- MENU -->
                <div class="dropdown">
                    <button class="btn btn-light btn-sm rounded-circle shadow-sm"
                            type="button"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">

                        <!-- SỬA -->
                        <li>
                            <a class="dropdown-item py-2"
                                   href="/TodoTasks/Edit/@task.Id">
                                <i class="bi bi-pencil me-2 text-primary"></i> Sửa
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <!-- XÓA -->
                        <li>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-trash me-2"></i> Xóa
                                </button>
                            </form>
                        </li>

                    </ul>
                </div>

            </div>
        </div>
    }
</div>

<!-- MODAL CREATE -->
<div class="modal fade" id="createTaskModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Nhiệm vụ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-controller="TodoTasks" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tiêu đề</label>
                        <input name="Title" class="form-control rounded-3" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mô tả</label>
                        <textarea name="Description" class="form-control rounded-3"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Hạn chót</label>
                            <input name="Deadline" type="date" class="form-control rounded-3">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Danh mục</label>
                            <select name="danhMuc" class="form-select rounded-3">
                                <option value="">-- Chọn danh mục --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var item in ViewBag.Categories)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            Lưu nhiệm vụ
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>