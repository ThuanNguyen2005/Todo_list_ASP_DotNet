@using Todo_list.Models
@{
    // TẠO DỮ LIỆU GIẢ HOÀN TOÀN Ở ĐÂY
    var tasksToDisplay = new List<dynamic>
    {
        new {
            Title = "Thiết kế Sidebar",
            Description = "Hoàn thiện CSS cho menu bên trái",
            IsCompleted = false,
            DueDate = DateTime.Now,
            Category = new { Name = "Design" }
        },
        new {
            Title = "Chỉnh sửa nút Search",
            Description = "Thay chữ thành icon kính lúp",
            IsCompleted = true,
            DueDate = DateTime.Now.AddDays(1),
            Category = new { Name = "Học tập" }
        },
        new {
            Title = "Kiểm tra Responsive",
            Description = "Xem trên điện thoại có đẹp không",
            IsCompleted = false,
            DueDate = DateTime.Now.AddDays(2),
            Category = new { Name = "Mobile" }
        }
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Danh sách nhiệm vụ</h2>
    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createTaskModal">
    <i class="bi bi-plus-lg"></i> Tạo nhiệm vụ mới
</button>
</div>

<div class="todo-list">
    @foreach (var task in tasksToDisplay)
    {
        <div id="task-item" class="card mb-2 shadow-sm border-0 rounded-3 task-card">
            <div class="card-body d-flex align-items-center p-3">
                <input type="checkbox" class="form-check-input me-3" @(task.IsCompleted ? "checked" : "") style="width: 22px; height: 22px;">
                
                <div class="flex-grow-1">
                    <h6 class="mb-0 @(task.IsCompleted ? "text-decoration-line-through text-muted" : "fw-bold")">
                        @task.Title
                    </h6>
                    <small class="text-muted">
                        @task.Description | <i class="bi bi-clock"></i> @task.DueDate.ToString("dd/MM/yyyy")
                    </small>
                </div>

                <span class="badge bg-info-soft text-info rounded-pill me-3 px-3">
                    @task.Category.Name
                </span>

                <div class="dropdown">
                    <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li>
                            <a class="dropdown-item py-2" href="#" data-bs-toggle="modal" data-bs-target="#editTaskModal">
                                <i class="bi bi-pencil me-2 text-primary"></i> Sửa nhiệm vụ
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item py-2 text-danger" href="#" data-bs-toggle="modal" data-bs-target="#deleteTaskModal">
                                <i class="bi bi-trash me-2"></i> Xóa nhiệm vụ
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>
<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Nhiệm vụ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="TodoTasks" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tiêu đề</label>
                        <input type="text" class="form-control rounded-3" placeholder="Bạn cần làm gì?">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mô tả</label>
                        <textarea class="form-control rounded-3" rows="3" placeholder="Chi tiết công việc..."></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Ngày hết hạn</label>
                            <input type="date" class="form-control rounded-3">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Danh mục</label>
                            <select class="form-select rounded-3">
                                <option>Học tập</option>
                                <option>Công việc</option>
                                <option>Cá nhân</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary rounded-pill px-4">Lưu nhiệm vụ</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4 text-center">
            <div class="modal-body p-4">
                <i class="bi bi-exclamation-circle text-danger display-4 mb-3"></i>
                <h5 class="fw-bold">Xác nhận xóa?</h5>
                <p class="text-muted small">Bạn có chắc muốn xóa nhiệm vụ này không?</p>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-light w-100 rounded-pill" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-100 rounded-pill">Xóa ngay</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Chỉnh sửa nhiệm vụ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control mb-3" value="Thiết kế Sidebar">
                <textarea class="form-control mb-3">Hoàn thiện CSS cho menu bên trái</textarea>
                <button type="button" class="btn btn-primary w-100 rounded-pill">Cập nhật</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            // Khi bấm vào nút "Xóa ngay" trong Modal
            $('#deleteTaskModal .btn-danger').click(function () {
                // Giả lập xóa: Tìm card đang hiển thị menu và ẩn nó đi
                // Trong thực tế demo, ta có thể xóa card đầu tiên hoặc card cụ thể
                $('.task-card').first().fadeOut(500, function() {
                    $(this).remove();
                });

                // Đóng modal sau khi xóa
                $('#deleteTaskModal').modal('hide');
                
                // Hiển thị thông báo nhỏ (tùy chọn)
                alert("Đã xóa nhiệm vụ thành công!");
            });
        });
    </script>
}